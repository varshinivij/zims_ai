<launch>

<rosparam file="$(find SpdrBot_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="SpdrBot" args="Revolute 77_position_controller Revolute 78_position_controller Revolute 79_position_controller Revolute 80_position_controller Revolute 90_position_controller Revolute 91_position_controller Revolute 92_position_controller Revolute 93_position_controller Revolute 102_position_controller Revolute 103_position_controller Revolute 104_position_controller Revolute 105_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/SpdrBot/joint_states"/>
</node>

</launch>